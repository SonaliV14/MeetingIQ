# Copy to .env and fill in. Only the stages you run need their keys.

# Stage 2 — LLM expansion (transcripts/emails/docs + signal weaving)
ANTHROPIC_API_KEY=
SYNTHGEN_LLM_MODEL=claude-sonnet-4-6
SYNTHGEN_LLM_HEAVY=claude-opus-4-8

# Stage 3 — TTS for the 12 calls.  openai | azure | elevenlabs | pyttsx3(offline)
SYNTHGEN_TTS=openai
OPENAI_API_KEY=

# Stage 4 — Whisper.  local(faster-whisper, no key) | api(openai)
SYNTHGEN_WHISPER=local

# Stage 6 — data stores (from docker-compose)
DATABASE_URL=postgresql://meetingiq:meetingiq@localhost:5432/meetingiq
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=meetingiq

# Optional: override output dir
# SYNTHGEN_OUT=./out
